<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AnkiEnglishCardsBuilder.ViewModels"
        xmlns:m="using:AnkiEnglishCardsBuilder.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1240"
        d:DesignHeight="780"
        x:Class="AnkiEnglishCardsBuilder.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Anki English Cards Builder"
        Width="1240"
        Height="780"
        MinWidth="1040"
        MinHeight="680"
        Background="#090D14">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#38BDF8"/>
            <Setter Property="Foreground" Value="#06111F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#93C5FD"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="TextBlock.muted">
            <Setter Property="Foreground" Value="#7EA6D9"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#0E1420"/>
            <Setter Property="BorderBrush" Value="#1D3557"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Foreground" Value="#DBEAFE"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#264A73"/>
            <Setter Property="SelectionBrush" Value="#2563EB"/>
        </Style>
        <Style Selector="DataGrid">
            <Setter Property="Foreground" Value="#DBEAFE"/>
            <Setter Property="Background" Value="#0B1220"/>
            <Setter Property="BorderBrush" Value="#1D3557"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#60A5FA"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="#0B1220"/>
        </Style>
        <Style Selector="DataGridRow:nth-child(even)">
            <Setter Property="Background" Value="#0E1726"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="BorderBrush" Value="#1B2C44"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="24" RowSpacing="16">
        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
            <StackPanel Spacing="5">
                <TextBlock Text="Anki English Cards Builder"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#60A5FA"/>
                <TextBlock Text="Genera note TSV revisionabili da importare in Anki."
                           Classes="muted"
                           FontSize="14"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Top">
                <Border Background="#102A43" BorderBrush="#22D3EE" BorderThickness="1" CornerRadius="8" Padding="12,8">
                    <TextBlock Text="{Binding ProviderSummary}" Foreground="#67E8F9" FontWeight="SemiBold"/>
                </Border>
                <Button Content="Settings" Classes="secondary" Click="OpenSettings_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="390,*" ColumnSpacing="16">
            <Border Classes="panel" Padding="18">
                <Grid RowDefinitions="Auto,*,Auto,Auto" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Parole da imparare" FontSize="18" FontWeight="SemiBold" Foreground="#93C5FD"/>
                            <TextBlock Text="Separale con virgole, punto e virgola o nuove righe."
                                       Classes="muted"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="#1D3557" BorderBrush="#38BDF8" BorderThickness="1"
                                CornerRadius="12" Padding="10,4" VerticalAlignment="Center">
                            <TextBlock Foreground="#67E8F9" FontWeight="SemiBold" FontSize="13">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} parole">
                                        <Binding Path="WordCount"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <TextBox Grid.Row="1"
                             Text="{Binding InputText, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             PlaceholderText="abroad, reliable, thoughtful"
                             FontSize="15"
                             Padding="12"
                             Background="#0B1220"
                             BorderBrush="#264A73"/>

                    <StackPanel Grid.Row="2" Spacing="10">
                        <Button Content="Generate with LLM"
                                Classes="primary"
                                Command="{Binding GenerateCommand}"
                                IsEnabled="{Binding !IsBusy}"/>
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Button Content="Parse only"
                                    Classes="secondary"
                                    Command="{Binding ParseOnlyCommand}"
                                    IsEnabled="{Binding !IsBusy}"/>
                            <Button Grid.Column="1"
                                    Content="Cancel"
                                    Classes="secondary"
                                    Command="{Binding CancelGenerationCommand}"
                                    IsEnabled="{Binding IsBusy}"/>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Row="3" Background="#0B1220" BorderBrush="#22D3EE" BorderThickness="1" CornerRadius="8" Padding="12">
                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding StatusMessage}" FontWeight="SemiBold" Foreground="#67E8F9" TextWrapping="Wrap"/>
                            <ProgressBar Value="{Binding ProgressPercent}"
                                         Maximum="100"
                                         IsVisible="{Binding IsBusy}"
                                         Height="6"
                                         CornerRadius="3"
                                         Background="#1D3557"
                                         Foreground="#38BDF8"/>
                            <TextBlock Text="{Binding DetailMessage}" Classes="muted" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="panel">
                <Grid RowDefinitions="Auto,*" RowSpacing="0">
                    <Grid ColumnDefinitions="*,Auto" Margin="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Preview card" FontSize="18" FontWeight="SemiBold" Foreground="#93C5FD"/>
                            <TextBlock Text="Modifica qualsiasi campo prima dell'export."
                                       Classes="muted"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="Export TSV"
                                Classes="primary"
                                VerticalAlignment="Center"
                                Click="Export_Click"
                                IsEnabled="{Binding HasCards}"/>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Cards}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              RowHeight="44"
                              BorderThickness="0"
                              Background="#0B1220"
                              IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Word" Binding="{Binding Word, Mode=TwoWay}" Width="130"/>
                            <DataGridTextColumn Header="POS" Binding="{Binding PartOfSpeech, Mode=TwoWay}" Width="95"/>
                            <DataGridTextColumn Header="Italian" Binding="{Binding ItalianMeaning, Mode=TwoWay}" Width="170"/>
                            <DataGridTextColumn Header="Definition" Binding="{Binding EnglishDefinition, Mode=TwoWay}" Width="260"/>
                            <DataGridTextColumn Header="Example" Binding="{Binding ExampleSentence, Mode=TwoWay}" Width="280"/>
                            <DataGridTextColumn Header="Translation" Binding="{Binding ExampleTranslation, Mode=TwoWay}" Width="260"/>
                            <DataGridTextColumn Header="Usage notes" Binding="{Binding UsageNotes, Mode=TwoWay}" Width="300"/>
                            <DataGridTextColumn Header="Synonyms" Binding="{Binding Synonyms, Mode=TwoWay}" Width="180"/>
                            <DataGridTextColumn Header="Error" Binding="{Binding Error}" Width="260" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Classes="panel">
            <Grid RowDefinitions="Auto,Auto">
                <Grid ColumnDefinitions="*,Auto" Margin="14,10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Activity log" Foreground="#93C5FD" FontWeight="SemiBold"/>
                        <TextBlock Text="Mostra provider, batch, warning, errori e operazioni di export."
                                   Classes="muted"
                                   FontSize="12"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Show / Hide"
                            Classes="secondary"
                            VerticalAlignment="Center"
                            Command="{Binding ToggleLogPanelCommand}"/>
                </Grid>

                <Border Grid.Row="1"
                        IsVisible="{Binding IsLogPanelVisible}"
                        Background="#080E18"
                        BorderBrush="#1D3557"
                        BorderThickness="0,1,0,0"
                        Padding="12"
                        MaxHeight="180">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"
                                               FontFamily="Consolas"
                                               FontSize="12"
                                               Foreground="#A5B4FC"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
